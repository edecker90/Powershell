# Update User Properties from CSV (export users from Entra)
Connect-MgGraph -Scopes User.ReadWrite.All
Import-Csv "C:\test.csv" | Foreach { 
 Update-MgUser -UserId $_.id -OfficeLocation $_.officeLocation -UsageLocation "US"
}

# Assign Licenses from CSV (export users from Entra)
Connect-Graph -Scopes User.ReadWrite.All, Organization.Read.All
$Sku = Get-MgSubscribedSku -All | Where SkuPartNumber -eq 'EXCHANGESTANDARD'
Import-Csv "C:\temp\exch1.csv" | Foreach { 
 Set-MgUserLicense -UserId $_.id -AddLicenses @{SkuId = $Sku.SkuId} -RemoveLicenses @()
}
